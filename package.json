{
  "name": "alpha-video-player-js",
  "version": "1.1.0",
  "description": "Web 视频动画特效播放 sdk",
  "main": "dist/alpha-video-player-js.js",
  "types": "dist/alpha-video-player-js.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/alpha-video-player-js.js",
      "types": "./dist/alpha-video-player-js.d.ts"
    },
    "./vue3": {
      "import": "./dist/vue3.js",
      "types": "./dist/vue3.d.ts"
    },
    "./vue2": {
      "import": "./dist/vue2.js",
      "types": "./dist/vue2.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "scripts": {
    "dev": "rollup -c -w",
    "build": "cross-env NODE_ENV=production rollup -c",
    "release": "bash ./scripts/release.sh",
    "postpublish": "git push && git push --tags"
  },
  "keywords": [
    "alpha",
    "video",
    "player",
    "webgl",
    "canvas",
    "vue",
    "react"
  ],
  "author": "https://github.com/trp1119",
  "license": "ISC",
  "repository": "https://github.com/trp1119/alpha-video-player-js",
  "homepage": "https://trp1119.github.io/alpha-video-player-js-demo",
  "files": [
    "dist",
    "package.json"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "peerDependencies": {
    "vue": "^2.7.0 || ^3.0.0",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.0.0",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-terser": "^0.4.3",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "cross-env": "^7.0.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rollup": "^3.29.2",
    "rollup-plugin-dts": "^6.0.2",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-glslify": "^1.3.1",
    "rollup-plugin-typescript2": "^0.35.0",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vue": "^3.0.0",
    "vue2": "npm:vue@^2.7.0"
  }
}
